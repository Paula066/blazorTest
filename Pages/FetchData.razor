@page "/fetchdata"
@using System.Text.Json

<PageTitle>Prognoza pogody</PageTitle>

<h1>Prognoza pogody</h1>

<p>Ten komponent pobiera dane bezposrednio z serwera (bez HTTP - to sila Blazor Server!).</p>

@if (forecasts == null)
{
    <p><em>Ladowanie danych...</em></p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Data</th>
                <th>Temp. (C)</th>
                <th>Temp. (F)</th>
                <th>Opis</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var forecast in forecasts)
            {
                <tr>
                    <td>@forecast.Date.ToShortDateString()</td>
                    <td>@(forecast.TemperatureC)@("\u00B0")C</td>
                    <td>@(32 + (int)(forecast.TemperatureC / 0.5556))@("\u00B0")F</td>
                    <td>@forecast.Summary</td>
                </tr>
            }
        </tbody>
    </table>

    <div class="alert alert-info mt-3">
        <strong>Wskazowka:</strong> W Blazor Server mozesz bezposrednio korzystac z bazy danych
        (Entity Framework, Dapper) bez potrzeby tworzenia API!
    </div>
}

@code {
    private WeatherForecast[]? forecasts;

    protected override async Task OnInitializedAsync()
    {
        await Task.Delay(100);

        var jsonPath = Path.Combine(Directory.GetCurrentDirectory(), "wwwroot", "sample-data", "weather.json");
        if (File.Exists(jsonPath))
        {
            var json = await File.ReadAllTextAsync(jsonPath);
            forecasts = JsonSerializer.Deserialize<WeatherForecast[]>(json, new JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            });
        }
    }

    public class WeatherForecast
    {
        public DateTime Date { get; set; }
        public int TemperatureC { get; set; }
        public string? Summary { get; set; }
    }
}
