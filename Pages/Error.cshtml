@page
@model ElevatoBlazorApp.Pages.ErrorModel

<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Blad - Elevato</title>
    <link href="~/css/bootstrap/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/app.css" rel="stylesheet" />
</head>
<body>
    <div class="container mt-5">
        <h1 class="text-danger">Blad</h1>
        <h2 class="text-danger">Wystapil blad podczas przetwarzania Twojego zadania.</h2>
        @if (Model.ShowRequestId)
        {
            <p><strong>Request ID:</strong> <code>@Model.RequestId</code></p>
        }
        <a href="/" class="btn btn-primary mt-3">Wroc na strone glowna</a>
    </div>
</body>
</html>
